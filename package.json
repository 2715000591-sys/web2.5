{
  "name": "web2.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node backend/server.mjs",
    "backend": "node backend/server.mjs",
    "cloud:dev": "npx wrangler@latest dev",
    "browser:artifacts": "bash scripts/prepare-download-bundles.sh",
    "cloud:deploy": "npm run browser:artifacts && npx wrangler@latest deploy",
    "cloud:check": "npx wrangler@latest deploy --dry-run",
    "cloud:audit-data-layer": "node scripts/audit-data-layer.mjs",
    "cloud:d1:apply:local": "npx wrangler@latest d1 execute web25 --local --file=cloudflare/schema.sql",
    "safari:build": "bash scripts/build-safari-app.sh",
    "safari:verify-live": "bash scripts/verify-safari-extension-live.sh",
    "console:open": "bash scripts/open-console.sh",
    "console:status": "bash scripts/backend-status.sh",
    "console:install-autostart": "bash scripts/install-autostart.sh",
    "console:remove-autostart": "bash scripts/uninstall-autostart.sh"
  }
}
